# Telegram API credentials (from my.telegram.org)
API_ID=12345678
API_HASH=your_api_hash_here

# Bot token (from @BotFather)
BOT_TOKEN=1234567890:AAExampleBotTokenHere

# String session (for userbot / Pyrogram / Telethon)
BOT_SESSION=vjbot

# Database (MongoDB example)
DATABASE_URI=mongodb+srv://username:password@cluster0.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=vj-forward-bot

# Owner user ID (your Telegram numeric ID)
BOT_OWNER=123456789
